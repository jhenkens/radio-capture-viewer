{
  "name": "radio-capture-viewer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run build:client:dev && concurrently --kill-others-on-fail --names server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "webpack --config webpack.config.ts --mode development --watch",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "webpack --config webpack.config.ts --mode production",
    "build:client:dev": "webpack --config webpack.config.ts --mode development",
    "build": "npm run build:server && npm run build:client",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx src/server/scripts/seed.ts",
    "stats": "tsx src/server/scripts/stats.ts",
    "lint": "tsc --noEmit",
    "docker:build": "docker build -t radio-capture-viewer:latest . && docker build -t radio-capture-viewer:importer-latest ./importer"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "alpinejs": "^3.14.1",
    "better-sqlite3": "^9.6.0",
    "c12": "^4.0.0-beta.4",
    "drizzle-orm": "^0.31.4",
    "fastify": "^4.28.1",
    "music-metadata": "^11.12.3",
    "openai": "^4.52.7",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@types/better-sqlite3": "^7.6.11",
    "@types/html-webpack-plugin": "^3.2.9",
    "@types/node": "^20.14.11",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.11",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "css-loader": "^7.1.2",
    "drizzle-kit": "^0.22.8",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.0",
    "postcss": "^8.4.39",
    "postcss-loader": "^8.1.1",
    "tailwindcss": "^3.4.6",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "webpack": "^5.93.0",
    "webpack-cli": "^5.1.4"
  }
}
