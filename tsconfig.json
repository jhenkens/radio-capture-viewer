{
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "node",
      "esModuleInterop": true
    }
  },
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist/client",
    "rootDir": "src",
    "sourceMap": true
  },
  "include": ["src/client", "src/shared"],
  "exclude": ["node_modules", "dist"]
}
